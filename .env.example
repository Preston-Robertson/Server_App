# /etc/gamesrv.env  (chmod 640, root:gamesrv)
# Copy to /etc/gamesrv.env and fill in real values. DO NOT COMMIT.

# --- Manager auth (bearer token for the web UI / API) ---
# Generate:  python3 -c "import secrets;print(secrets.token_urlsafe(48))"
GAMESRV_TOKEN=changeme-generate-a-real-token

# --- Bind address / port for the FastAPI manager ---
GAMESRV_HOST=0.0.0.0
GAMESRV_PORT=8765

# --- Paths (override only if you moved things) ---
GAMESRV_APP_DIR=/opt/gamesrv
GAMESRV_DEFS_DIR=/opt/gamesrv/servers
GAMESRV_INSTALL_ROOT=/srv/gameservers
GAMESRV_WORLDS_ROOT=/opt/gamesrv/worlds
GAMESRV_BACKUP_ROOT=/opt/gamesrv/worlds/_backups

# --- Systemd template unit name (see systemd/gamesrv@.service) ---
GAMESRV_UNIT_TEMPLATE=gamesrv@

# --- Optional: GitHub PAT for pulling a PRIVATE app repo during self-update ---
# Fine-grained PAT, Contents: Read-only, scoped to THIS repo only.
GAMESRV_GITHUB_TOKEN=

# --- Optional: per-server RCON / secret passwords ---
# Referenced from server YAML via password_env: MC_SMP_RCON_PW
# MC_SMP_RCON_PW=change-me
# PALWORLD_ADMIN_PW=change-me

# --- Optional: per-server git-source PATs ---
# Referenced from server YAML via git_source.token_env
# Fine-grained PAT (Contents: Read-only), scoped to just the target repo.
# Works for GitHub AND self-hosted Gitea/Forgejo — same URL/PAT semantics.
# MC_FORGE_GIT_PAT=github_pat_xxx
# PALWORLD_GIT_PAT=github_pat_xxx
