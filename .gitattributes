# Force LF line endings for all Linux-run files. Prevents Windows CRLF
# from creeping in via editors/git config and breaking shebangs on the LXC.
* text=auto eol=lf

*.sh    text eol=lf
*.py    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.env   text eol=lf
*.rules text eol=lf
*.service text eol=lf
*.md    text eol=lf
*.html  text eol=lf
*.css   text eol=lf
*.js    text eol=lf

# Binary shouldn't be normalized.
*.jar   binary
*.zip   binary
*.tgz   binary
*.gz    binary
*.png   binary
*.jpg   binary
